@page
@model RecipeApp.Web.Pages.MyFavoritesModel
@{
    ViewData["Title"] = "Os Meus Favoritos";
}

<div class="container py-4 animate__animated animate__fadeIn">
    @* --- MENSAGEM DE FEEDBACK --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="fas fa-heart text-danger me-2"></i>As Minhas Escolhas
            </h2>
            <p class="text-muted mb-0">Todas as receitas que guardaste para cozinhar mais tarde.</p>
        </div>
        <a asp-page="/Index" class="btn btn-outline-dark rounded-pill px-4 fw-bold shadow-sm">
            <i class="fas fa-search me-2"></i>Explorar Mais
        </a>
    </div>

    @if (Model.Recipes == null || !Model.Recipes.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center py-5 border-2 border-dashed">
            <div class="card-body py-5">
                <div class="display-1 text-muted opacity-25 mb-3">
                    <i class="fas fa-heart-broken"></i>
                </div>
                <h4 class="text-secondary fw-bold">A tua lista está vazia!</h4>
                <p class="text-muted mb-4">Ainda não tens receitas favoritas. Começa a explorar e clica no ❤️ das receitas que mais gostares.</p>
                <a asp-page="/Index" class="btn btn-danger rounded-pill px-5 shadow-sm fw-bold py-2">
                    Ir para as Receitas
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var r in Model.Recipes)
            {
                <div class="col-md-6 col-lg-4 animate__animated animate__fadeInUp">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden recipe-card">
                        <div class="position-relative">
                            @* Imagem dinâmica via ID para dar variedade visual *@
                            <img src="https://loremflickr.com/800/500/food,recipe?lock=@r.RecipeId" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@r.Title">

                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-white text-dark rounded-pill shadow-sm px-3 py-2">
                                    <i class="far fa-clock text-warning me-1"></i> @r.PreparationTime min
                                </span>
                            </div>

                            @* Overlay de categoria *@
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="badge bg-success rounded-pill shadow-sm px-3">
                                    @r.CategoryName
                                </span>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold mb-3 text-dark">@r.Title</h5>

                            <div class="d-flex align-items-center gap-3 mb-4 text-muted small">
                                <span><i class="fas fa-signal text-primary me-1"></i> @r.DifficultyName</span>
                                @* CORREÇÃO AQUI: Usamos IngredientsCount em vez do Count da lista *@
                                <span><i class="fas fa-utensils text-secondary me-1"></i> @r.IngredientsCount Ingredientes</span>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-page="/RecipeDetails" asp-route-id="@r.RecipeId"
                                   class="btn btn-dark rounded-pill w-100 fw-bold">
                                    <i class="fas fa-eye me-2"></i>Ver Receita
                                </a>

                                <form method="post" asp-page-handler="ToggleFavorite" asp-route-id="@r.RecipeId"
                                      class="d-inline" onsubmit="return confirm('Remover dos favoritos?');">
                                    <button type="submit" class="btn btn-outline-danger rounded-circle p-2 px-3 shadow-sm" title="Remover dos favoritos">
                                        <i class="fas fa-heart"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .recipe-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .recipe-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    /* Estilo para o botão de remover quando é o coração */
    .btn-outline-danger {
        border-color: #f8d7da;
    }

        .btn-outline-danger:hover {
            background-color: #dc3545;
            border-color: #dc3545;
            color: white;
        }
</style>