@page "{recipeId:long}"
@model RecipeApp.Web.Pages.EditIngredientsModel
@{
    ViewData["Title"] = "Editar Ingredientes";
}

<div class="container py-4 animate__animated animate__fadeIn">
    @* --- CABEÇALHO --- *@
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">🧂 Ingredientes da Receita</h2>
            <h4 class="text-success opacity-75">@Model.Recipe.Title</h4>
        </div>
        <a asp-page="/MyRecipes" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="fas fa-chevron-left me-2"></i>Voltar
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @* --- COLUNA DA ESQUERDA: ADICIONAR NOVO --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="fas fa-plus-circle text-success me-2"></i>Adicionar Novo</h5>

                    <form method="post" asp-page-handler="Add">
                        @* Passamos o ID da receita corretamente *@
                        <input type="hidden" name="recipeId" value="@Model.Recipe.RecipeId" />

                        <div class="mb-3">
                            <label asp-for="SelectedIngredientId" class="form-label small fw-bold">Ingrediente</label>
                            <select class="form-select shadow-sm" asp-for="SelectedIngredientId" required>
                                <option value="">Selecione o ingrediente...</option>
                                @foreach (var i in Model.AllIngredients)
                                {
                                    <option value="@i.IngredientId">@i.Name</option>
                                }
                            </select>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label asp-for="Quantity" class="form-label small fw-bold">Qtd.</label>
                                @* Mudado para type="text" para aceitar decimais de forma mais flexível no modelo string *@
                                <input class="form-control shadow-sm" asp-for="Quantity" placeholder="Ex: 500" required />
                            </div>
                            <div class="col-6">
                                <label asp-for="Unit" class="form-label small fw-bold">Unidade</label>
                                <input class="form-control shadow-sm" asp-for="Unit" placeholder="Ex: g, ml, dose" required />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-bold shadow-sm transition-hover">
                            <i class="fas fa-plus me-2"></i>Adicionar à Lista
                        </button>
                    </form>
                </div>
            </div>
        </div>

        @* --- COLUNA DA DIREITA: LISTA ATUAL --- *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 min-vh-50">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="fas fa-list text-primary me-2"></i>Ingredientes na Receita</h5>

                    @if (Model.Ingredients == null || !Model.Ingredients.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-mortar-pestle text-muted opacity-25 display-1 mb-3"></i>
                            <p class="text-muted">Ainda não foram adicionados ingredientes a esta receita.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ingrediente</th>
                                        <th class="text-center">Quantidade</th>
                                        <th class="text-center">Unidade</th>
                                        <th class="text-end">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ing in Model.Ingredients)
                                    {
                                        <tr class="animate__animated animate__fadeIn">
                                            @* Ajustado para .Name (que existe no seu modelo Ingredient) *@
                                            <td class="fw-bold">@ing.Name</td>
                                            <td class="text-center">@ing.Quantity</td>
                                            @* Ajustado para .Unit *@
                                            <td class="text-center">
                                                <span class="badge bg-light text-dark border">@(string.IsNullOrEmpty(ing.Unit) ? "-" : ing.Unit)</span>
                                            </td>
                                            <td class="text-end">
                                                <form method="post" asp-page-handler="Remove" onsubmit="return confirm('Remover este ingrediente?');">
                                                    <input type="hidden" name="recipeId" value="@Model.Recipe.RecipeId" />
                                                    <input type="hidden" name="ingredientId" value="@ing.IngredientId" />
                                                    <button type="submit" class="btn btn-link text-danger p-0" title="Remover">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.2s ease;
    }

        .transition-hover:hover {
            transform: scale(1.02);
        }

    .min-vh-50 {
        min-height: 400px;
    }

    .table-hover tbody tr:hover {
        background-color: #f8fff9;
    }
</style>