@page
@model RecipeApp.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-5">
            <div class="card auth-card shadow-lg border-0">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <div class="display-4 text-success mb-2">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Bem-vindo de volta!</h2>
                        <p class="text-muted">Inicie sessão para gerir as suas receitas.</p>
                    </div>

                    <form method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 shadow-sm small" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                <div asp-validation-summary="All" class="d-inline"></div>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold small text-uppercase">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="fas fa-envelope"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="exemplo@email.com" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold small text-uppercase">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="fas fa-lock"></i>
                                </span>
                                <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm transition-hover">
                            Entrar na Conta
                        </button>

                        <div class="text-center mt-4">
                            <p class="text-muted small">
                                Não tem uma conta?
                                <a asp-page="/Register" class="text-success fw-bold text-decoration-none">Registe-se aqui</a>
                            </p>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Pequeno ajuste extra para animação no botão */
    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(39, 174, 96, 0.3) !important;
        }
</style>