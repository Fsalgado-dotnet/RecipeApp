@page
@model RecipeApp.Web.Pages.MyRecipesModel
@{
    ViewData["Title"] = "As Minhas Receitas";
}

<div class="container py-4 animate__animated animate__fadeIn">
    @* --- FEEDBACK DE AÇÕES --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-pill px-4 shadow-sm mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-book-open text-success me-2"></i>As Minhas Receitas</h2>
            <p class="text-muted mb-0">Faça a gestão e acompanhe o estado das suas publicações.</p>
        </div>
        <a asp-page="/CreateRecipe" class="btn btn-success rounded-pill px-4 py-2 shadow-sm fw-bold">
            <i class="fas fa-plus me-2"></i>Criar Nova Receita
        </a>
    </div>

    @if (Model.Recipes == null || !Model.Recipes.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center py-5 border-2 border-dashed">
            <div class="card-body">
                <div class="display-1 text-muted opacity-25 mb-3">🍳</div>
                <h4 class="text-secondary fw-bold">Ainda não partilhou o seu talento!</h4>
                <p class="text-muted mb-4">Crie a sua primeira receita e partilhe-a com o mundo.</p>
                <a asp-page="/CreateRecipe" class="btn btn-outline-success rounded-pill px-5 fw-bold">
                    Começar Agora
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 border-0 text-uppercase small fw-bold text-muted">Receita</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Estado</th>
                            <th class="py-3 border-0 text-uppercase small fw-bold text-muted text-end pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var recipe in Model.Recipes)
                        {
                            <tr>
                                <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-3 p-2 me-3 text-success shadow-sm">
                                            <i class="fas fa-mortar-pestle fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark fs-5">@recipe.Title</div>
                                            <small class="text-muted">Criada em @recipe.CreatedAt.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (recipe.IsApproved)
                                    {
                                        <span class="badge rounded-pill bg-success-light text-success px-3 py-2">
                                            <i class="fas fa-check-circle me-1"></i> Aprovada
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning-light text-warning px-3 py-2">
                                            <i class="fas fa-clock me-1"></i> Pendente
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill bg-white border overflow-hidden">
                                        <a asp-page="/RecipeDetails" asp-route-id="@recipe.RecipeId"
                                           class="btn btn-white border-0 text-primary px-3" title="Visualizar">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-page="/EditRecipe" asp-route-id="@recipe.RecipeId"
                                           class="btn btn-white border-0 text-warning px-3 border-start" title="Editar Detalhes">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-page="/EditIngredients" asp-route-recipeId="@recipe.RecipeId"
                                           class="btn btn-white border-0 text-secondary px-3 border-start" title="Gerir Ingredientes">
                                            <i class="fas fa-carrot"></i>
                                        </a>

                                        @* Formulário de Eliminação *@
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.RecipeId"
                                              style="display:inline;" onsubmit="return confirm('ATENÇÃO: Esta ação é irreversível. Deseja eliminar permanentemente esta receita?');">
                                            <button type="submit" class="btn btn-white border-0 text-danger px-3 border-start" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .bg-success-light {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-light {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .table tbody tr {
        transition: all 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: #fcfdfc;
            transform: scale(1.001);
        }

    .btn-group .btn:hover {
        background-color: #f8f9fa;
    }

    .bg-warning-light i {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>