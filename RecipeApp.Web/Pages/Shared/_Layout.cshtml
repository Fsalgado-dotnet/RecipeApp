@using RecipeApp.Services
@using RecipeApp.Models
@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChefShare</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                    <span class="fs-2 me-2">🍳</span>
                    <span class="fw-bold">Chef<span class="text-success">Share</span></span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item"><a class="nav-link px-3" asp-page="/Index">Início</a></li>

                        @if (SessionHelper.IsLoggedIn(Context))
                        {
                            <li class="nav-item"><a class="nav-link px-3" asp-page="/CreateRecipe">Criar Receita</a></li>
                            <li class="nav-item"><a class="nav-link px-3" asp-page="/MyRecipes">As Minhas Receitas</a></li>
                        }

                        @if (SessionHelper.IsAdmin(Context))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-success px-3" asp-page="/Admin/ApproveRecipes">
                                    <i class="fas fa-shield-alt me-1"></i> Moderação
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (!SessionHelper.IsLoggedIn(Context))
                        {
                            <li class="nav-item"><a class="nav-link me-2" asp-page="/Login">Entrar</a></li>
                            <li class="nav-item">
                                <a class="btn btn-success rounded-pill px-4 shadow-sm fw-bold" asp-page="/Register">Registar</a>
                            </li>
                        }
                        else
                        {
                            var loggedUser = SessionHelper.GetUser(Context);
                            string displayLabel = loggedUser?.Name ?? "Utilizador";

                            <li class="nav-item dropdown">
                                <a class="btn btn-outline-dark rounded-pill dropdown-toggle px-3 shadow-sm d-flex align-items-center"
                                   href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle me-2 text-success fs-5"></i>
                                    @displayLabel
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2 animate__animated animate__fadeIn">
                                    <li class="px-3 py-2 small text-muted border-bottom mb-2">
                                        Olá, <strong>@displayLabel</strong>
                                    </li>
                                    @* Favoritos movidos para dentro do menu do utilizador *@
                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/MyFavorites">
                                            <i class="fas fa-heart text-danger me-2 opacity-75"></i>Os Meus Favoritos
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/MyRecipes">
                                            <i class="fas fa-utensils me-2 opacity-50"></i>As Minhas Receitas
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger fw-bold" asp-page="/Logout">
                                            <i class="fas fa-sign-out-alt me-2"></i>Sair
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @* Hero Section apenas na Home *@
    @if (ViewData["Title"]?.ToString() == "Home" || ViewData["Title"]?.ToString() == "Início")
    {
        <section class="text-white d-flex align-items-center"
                 style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1495521821757-a1efb6729352?q=80&w=1500'); background-size: cover; background-position: center; min-height: 400px;">
            <div class="container py-5">
                <div class="row animate__animated animate__fadeInUp">
                    <div class="col-lg-8 text-center text-lg-start">
                        <h1 class="display-3 fw-bold mb-3">Cozinha com Paixão</h1>
                        <p class="lead mb-4 opacity-75">Milhares de receitas aprovadas pela comunidade.</p>
                        <a href="#main-content" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold shadow">Explorar</a>
                    </div>
                </div>
            </div>
        </section>
    }

    <main role="main" id="main-content" class="flex-grow-1">
        <div class="container py-5">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <h5 class="fw-bold mb-2">ChefShare</h5>
                    <p class="small mb-0 opacity-75">&copy; 2026 — Feito para amantes de comida.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="d-flex justify-content-center justify-content-md-end gap-3">
                        <a href="#" class="text-white-50 transition-hover"><i class="fab fa-instagram fs-4"></i></a>
                        <a href="#" class="text-white-50 transition-hover"><i class="fab fa-facebook fs-4"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>