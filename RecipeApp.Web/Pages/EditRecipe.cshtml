@page
@model RecipeApp.Web.Pages.EditRecipeModel
@{
    ViewData["Title"] = "Editar Receita";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            @* --- CABEÇALHO --- *@
            <div class="d-flex align-items-center mb-4">
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="fas fa-edit fa-2x text-warning"></i>
                </div>
                <div>
                    <h2 class="fw-bold mb-0">Editar Receita</h2>
                    <p class="text-muted mb-0">Aperfeiçoe os detalhes da sua obra-prima culinária.</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        @* Importante: Manter o ID e o UserID originais escondidos para o POST funcionar *@
                        <input type="hidden" asp-for="Recipe.RecipeId" />
                        <input type="hidden" asp-for="Recipe.CreatedByUserId" />
                        <input type="hidden" asp-for="Recipe.CreatedAt" />

                        <div class="row">
                            @* Título *@
                            <div class="col-12 mb-4">
                                <label asp-for="Recipe.Title" class="form-label fw-bold text-dark small text-uppercase">Título da Receita</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-utensils"></i></span>
                                    <input asp-for="Recipe.Title" class="form-control border-start-0 ps-0" placeholder="Ex: Bacalhau à Brás Especial" required />
                                </div>
                            </div>

                            @* Categoria e Dificuldade *@
                            <div class="col-md-6 mb-4">
                                <label asp-for="Recipe.CategoryId" class="form-label fw-bold text-dark small text-uppercase">Categoria</label>
                                <select asp-for="Recipe.CategoryId" asp-items="Model.Categories" class="form-select shadow-sm" required>
                                    <option value="">Selecione...</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Recipe.DifficultyId" class="form-label fw-bold text-dark small text-uppercase">Dificuldade</label>
                                <select asp-for="Recipe.DifficultyId" asp-items="Model.Difficulties" class="form-select shadow-sm" required>
                                    <option value="">Selecione...</option>
                                </select>
                            </div>

                            @* Tempo de Preparação *@
                            <div class="col-md-6 mb-4">
                                <label asp-for="Recipe.PreparationTime" class="form-label fw-bold text-dark small text-uppercase">Tempo (minutos)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="far fa-clock"></i></span>
                                    <input asp-for="Recipe.PreparationTime" type="number" class="form-control border-start-0 ps-0" min="1" required />
                                </div>
                            </div>

                            @* Método de Preparação *@
                            <div class="col-12 mb-4">
                                <label asp-for="Recipe.PreparationMethod" class="form-label fw-bold text-dark small text-uppercase">Modo de Preparação</label>
                                <textarea asp-for="Recipe.PreparationMethod" class="form-control shadow-sm" rows="6" placeholder="Descreva o passo-a-passo..." required></textarea>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        @* Botões de Ação *@
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-page="/MyRecipes" class="btn btn-light rounded-pill px-4 fw-bold text-muted">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-2 fw-bold shadow-sm transition-hover">
                                <i class="fas fa-save me-2"></i>Guardar Alterações
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Dica para o utilizador *@
            <div class="mt-4 p-3 bg-light rounded-3 border-start border-warning border-4">
                <p class="small mb-0 text-muted">
                    <i class="fas fa-info-circle text-warning me-2"></i>
                    <strong>Dica:</strong> Para editar os ingredientes, utilize a página dedicada de "Gestão de Ingredientes" no menu anterior.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        border-color: #27ae60;
        box-shadow: 0 0 0 0.25rem rgba(39, 174, 96, 0.1);
    }

    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(39, 174, 96, 0.3) !important;
        }
</style>