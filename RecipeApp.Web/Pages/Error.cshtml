@page
@model ErrorModel
@{
    ViewData["Title"] = "Ops! Algo correu mal";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">

            @* --- ILUSTRAÇÃO SIMPLES --- *@
            <div class="py-4">
                <i class="fas fa-cookie-bite text-success opacity-25" style="font-size: 100px;"></i>
            </div>

            <h1 class="fw-bold text-dark">@ViewData["Title"]</h1>
            <p class="lead text-muted mb-4">
                Parece que algo falhou na nossa cozinha digital. Não se preocupe, os nossos chefs já foram notificados.
            </p>

            @* --- REQUEST ID (Discreto e apenas se necessário) --- *@
            @if (Model.ShowRequestId)
            {
                <p class="text-muted small mb-5">
                    Caso precise de ajuda, indique este código ao suporte:
                    <span class="badge bg-light text-dark border fw-normal">@Model.RequestId</span>
                </p>
            }

            @* --- BOTÕES DE NAVEGAÇÃO --- *@
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-page="/Index" class="btn btn-success rounded-pill px-4 shadow-sm fw-bold">
                    Ir para a Página Inicial
                </a>
                <button onclick="history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                    Voltar Atrás
                </button>
            </div>

        </div>
    </div>
</div>