@page
@model RecipeApp.Web.Pages.CreateRecipeModel
@{
    ViewData["Title"] = "Criar Receita";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @* --- CABEÇALHO --- *@
            <div class="text-center mb-5">
                <span class="badge bg-success-light text-success rounded-pill px-4 py-2 fw-bold mb-3 text-uppercase tracking-wider">
                    Nova Partilha
                </span>
                <h1 class="fw-bold display-5">Partilha a tua Receita</h1>
                <p class="text-muted">Preenche os detalhes abaixo para inspirar outros amantes da cozinha.</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @* Linha de acento no topo *@
                <div class="bg-success" style="height: 6px; width: 100%;"></div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">

                        @* --- SUMÁRIO DE ERROS --- *@
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 animate__animated animate__shakeX">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <div asp-validation-summary="All" class="small d-inline"></div>
                            </div>
                        }

                        <div class="row g-4">
                            @* Título *@
                            <div class="col-12">
                                <label asp-for="Recipe.Title" class="form-label fw-bold small text-uppercase text-muted">Título da Receita</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light rounded-start-3"><i class="fas fa-heading text-success"></i></span>
                                    <input asp-for="Recipe.Title" class="form-control form-control-lg border-0 bg-light rounded-end-3"
                                           placeholder="Ex: Bacalhau à Brás Gourmet" required />
                                </div>
                            </div>

                            @* Método *@
                            <div class="col-12">
                                <label asp-for="Recipe.PreparationMethod" class="form-label fw-bold small text-uppercase text-muted">Modo de Preparação</label>
                                <textarea asp-for="Recipe.PreparationMethod" class="form-control border-0 bg-light rounded-3"
                                          rows="6" placeholder="Descreva o passo a passo da sua obra-prima..." required></textarea>
                            </div>

                            @* Tempo de Preparação *@
                            <div class="col-md-4">
                                <label asp-for="Recipe.PreparationTime" class="form-label fw-bold small text-uppercase text-muted">Tempo (min)</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light rounded-start-3"><i class="far fa-clock text-success"></i></span>
                                    <input asp-for="Recipe.PreparationTime" type="number" min="1"
                                           class="form-control border-0 bg-light rounded-end-3 text-center" required />
                                </div>
                            </div>

                            @* Categoria *@
                            <div class="col-md-4">
                                <label asp-for="Recipe.CategoryId" class="form-label fw-bold small text-uppercase text-muted">Categoria</label>
                                <select asp-for="Recipe.CategoryId" asp-items="Model.CategoryOptions" class="form-select border-0 bg-light rounded-3" required>
                                    <option value="">Selecionar...</option>
                                </select>
                            </div>

                            @* Dificuldade *@
                            <div class="col-md-4">
                                <label asp-for="Recipe.DifficultyId" class="form-label fw-bold small text-uppercase text-muted">Dificuldade</label>
                                <select asp-for="Recipe.DifficultyId" asp-items="Model.DifficultyOptions" class="form-select border-0 bg-light rounded-3" required>
                                    <option value="">Selecionar...</option>
                                </select>
                            </div>
                        </div>

                        @* --- BOTÕES DE ACÇÃO --- *@
                        <div class="mt-5 d-flex flex-column flex-md-row gap-3">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 flex-grow-1 shadow-sm transition-hover fw-bold">
                                <i class="fas fa-save me-2"></i>Seguinte: Ingredientes
                            </button>
                            <a asp-page="/Index" class="btn btn-light btn-lg rounded-pill px-4 text-muted border fw-bold">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            @* Dica no fundo *@
            <div class="mt-4 text-center animate__animated animate__fadeInUp animate__delay-1s">
                <div class="p-3 bg-white d-inline-block rounded-4 shadow-sm border">
                    <p class="small text-muted mb-0">
                        <i class="fas fa-lightbulb text-warning me-1"></i>
                        <strong>Próximo Passo:</strong> Após clicar em publicar, será levado para a gestão de ingredientes.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-light {
        background-color: rgba(39, 174, 96, 0.1);
    }

    .form-control, .form-select, .input-group-text {
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            background-color: #fff !important;
            box-shadow: 0 0 0 4px rgba(39, 174, 96, 0.15) !important;
            border: 1px solid #27ae60 !important;
        }

    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(39, 174, 96, 0.2) !important;
        }

    /* Estilo para labels pequenos e elegantes */
    .uppercase {
        text-transform: uppercase;
    }

    .tracking-wider {
        letter-spacing: 1px;
    }
</style>