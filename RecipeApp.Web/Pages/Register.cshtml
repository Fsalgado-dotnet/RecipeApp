@page
@model RecipeApp.Web.Pages.RegisterModel

<h2>Registar utilizador</h2>

<form method="post">

    <div asp-validation-summary="All" style="color:red"></div>

    <div>
        <label>Nome</label><br />
        <input asp-for="User.Name" />
    </div>

    <div>
        <label>Email</label><br />
        <input asp-for="User.Email" type="email" />
    </div>

    <div>
        <label>Password</label><br />
        <input asp-for="User.PasswordHash" type="password" />
    </div>

    <br />
    <button type="submit">Registar</button>
</form>
