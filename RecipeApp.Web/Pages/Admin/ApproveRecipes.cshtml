@page
@model RecipeApp.Web.Pages.Admin.ApproveRecipesModel
@{
    ViewData["Title"] = "Moderação de Receitas";
}

<div class="container py-4">
    <div class="mb-5">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-dark text-white rounded-3 p-3 shadow">
                <i class="fas fa-user-shield fs-3"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0">Painel de Moderação</h2>
                <p class="text-muted mb-0">Analise e aprove as receitas submetidas pela comunidade.</p>
            </div>
        </div>
    </div>

    @if (Model.PendingRecipes.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-4 bg-light py-5">
            <div class="card-body text-center">
                <div class="display-4 text-success opacity-50 mb-3">
                    <i class="fas fa-check-double"></i>
                </div>
                <h4 class="fw-bold text-dark">Tudo em dia!</h4>
                <p class="text-muted">Não existem receitas pendentes de aprovação neste momento.</p>
                <a asp-page="/Index" class="btn btn-dark rounded-pill px-4">Voltar ao Início</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-0 py-3 ps-4">
                        <span class="badge bg-warning-light text-warning rounded-pill px-3 py-2 fw-bold">
                            <i class="fas fa-hourglass-half me-1"></i> @Model.PendingRecipes.Count Pendentes
                        </span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0 text-uppercase small fw-bold text-muted">Receita</th>
                                    <th class="py-3 border-0 text-uppercase small fw-bold text-muted">Data de Submissão</th>
                                    <th class="py-3 border-0 text-uppercase small fw-bold text-muted text-end pe-4">Decisão</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var recipe in Model.PendingRecipes)
                                {
                                    <tr>
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center text-decoration-none text-dark">
                                                <div class="bg-success-light text-success rounded-circle p-2 me-3">
                                                    <i class="fas fa-file-alt"></i>
                                                </div>
                                                <span class="fw-bold fs-5">@recipe.Title</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span class="text-dark">@recipe.CreatedAt.ToString("dd MMM, yyyy")</span>
                                                <small class="text-muted">@recipe.CreatedAt.ToString("HH:mm")</small>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a asp-page="/RecipeDetails" asp-route-id="@recipe.RecipeId"
                                                   class="btn btn-light border btn-sm rounded-pill px-3 shadow-sm">
                                                    <i class="fas fa-eye me-1"></i> Rever
                                                </a>

                                                <form method="post" asp-page-handler="Approve" class="d-inline">
                                                    <input type="hidden" name="recipeId" value="@recipe.RecipeId" />
                                                    <button type="submit" class="btn btn-success btn-sm rounded-pill px-4 shadow-sm hover-grow">
                                                        <i class="fas fa-check me-1"></i> Aprovar
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Estilos específicos para moderação */
    .bg-warning-light {
        background-color: rgba(243, 156, 18, 0.1);
    }

    .bg-success-light {
        background-color: rgba(39, 174, 96, 0.1);
    }

    .hover-grow {
        transition: transform 0.2s ease;
    }

        .hover-grow:hover {
            transform: scale(1.05);
        }

    .table tbody tr {
        transition: all 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: rgba(39, 174, 96, 0.02);
        }
</style>