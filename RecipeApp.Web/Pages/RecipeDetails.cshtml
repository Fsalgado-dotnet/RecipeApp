@page "{id:long}"
@model RecipeApp.Web.Pages.RecipeDetailsModel
@using RecipeApp.Services
@{
    ViewData["Title"] = Model.Recipe?.Title ?? "Detalhes da Receita";
}

<div class="container mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="row mb-4 animate__animated animate__fadeIn">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Index" class="text-success text-decoration-none">Receitas</a></li>
                <li class="breadcrumb-item active">@Model.Recipe.Title</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <h1 class="display-4 fw-bold text-dark">@Model.Recipe.Title</h1>

            @if (SessionHelper.IsLoggedIn(HttpContext))
            {
                <form method="post" asp-page-handler="ToggleFavorite" asp-route-id="@Model.Recipe.RecipeId" class="ms-auto">
                    <button type="submit" class="btn @(Model.IsFavorite ? "btn-danger" : "btn-outline-danger") rounded-pill px-4 shadow-sm">
                        <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart me-2"></i>
                        @(Model.IsFavorite ? "Remover Favorito" : "Adicionar Favorito")
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<div class="row g-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">
            <img src="https://loremflickr.com/1200/600/food,cooking?lock=@Model.Recipe.RecipeId" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;" alt="Capa">
            <div class="card-body p-4 p-md-5">
                <h3 class="fw-bold mb-4">Modo de Preparação</h3>
                <p class="lead text-secondary" style="white-space: pre-line; line-height: 1.8;">
                    @Model.Recipe.PreparationMethod
                </p>
            </div>
        </div>

        @* --- SECÇÃO DE COMENTÁRIOS --- *@
        <div class="comments-section mt-5">
            <h3 class="fw-bold mb-4">
                <i class="far fa-comments me-2 text-success"></i>Comentários (@(Model.Comments?.Count ?? 0))
            </h3>

            @if (Model.Comments != null && Model.Comments.Any())
            {
                <div class="mb-5">
                    @foreach (var c in Model.Comments)
                    {
                        <div class="card border-0 shadow-sm mb-3 rounded-3 bg-light">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-bold text-dark">
                                        <i class="fas fa-user-circle me-1 text-muted"></i> @c.UserName
                                    </span>
                                    <small class="text-muted">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <p class="mb-0 text-secondary">@c.Text</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light border border-dashed text-center py-4 rounded-4 mb-5">
                    <p class="text-muted mb-0">Ainda não há comentários. Sê o primeiro a comentar!</p>
                </div>
            }

            @* --- FORMULÁRIO PARA ADICIONAR COMENTÁRIO --- *@
            @if (SessionHelper.IsLoggedIn(HttpContext))
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0">Deixa a tua opinião</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" asp-page-handler="AddComment" asp-route-id="@Model.Recipe.RecipeId">
                            <div class="mb-3">
                                <textarea asp-for="NewComment" class="form-control border-light shadow-none" rows="3"
                                          placeholder="O que achaste desta receita?" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
                                <i class="fas fa-paper-plane me-2"></i>Publicar Comentário
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning rounded-4 shadow-sm text-center mb-5">
                    <i class="fas fa-lock me-2"></i> Precisas de ter <a asp-page="/Login" class="fw-bold text-dark text-decoration-none">sessão iniciada</a> para comentar.
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        @* INGREDIENTES *@
        <div class="card border-0 shadow-sm rounded-4 mb-4 sticky-top" style="top: 100px; z-index: 10;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="fw-bold mb-0">Ingredientes</h4>
                    @if (SessionHelper.IsLoggedIn(HttpContext))
                    {
                        var user = SessionHelper.GetUser(HttpContext);
                        if (SessionHelper.IsAdmin(HttpContext) || (user != null && user.UserId == Model.Recipe.CreatedByUserId))
                        {
                            <a asp-page="/EditIngredients" asp-route-recipeId="@Model.Recipe.RecipeId" class="btn btn-sm btn-outline-secondary rounded-pill">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                        }
                    }
                </div>

                @if (Model.Ingredients == null || !Model.Ingredients.Any())
                {
                    <p class="text-muted small">Nenhum ingrediente listado.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var ing in Model.Ingredients)
                        {
                            <li class="py-2 border-bottom d-flex justify-content-between">
                                <span class="fw-semibold text-dark">@ing.Name</span>
                                <span class="text-success fw-bold">@ing.Quantity @ing.Unit</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        @* AVALIAÇÃO *@
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-success text-white">
            <div class="card-body p-4 text-center">
                <h4 class="fw-bold">Avaliação Média</h4>
                <div class="display-4 fw-bold">@Model.AverageRating.ToString("0.0")</div>
                <div class="mb-3 text-warning">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= Math.Round(Model.AverageRating) ? "fas" : "far") fa-star"></i>
                    }
                </div>

                @if (SessionHelper.IsLoggedIn(HttpContext))
                {
                    <form method="post" asp-page-handler="Rate" asp-route-id="@Model.Recipe.RecipeId">
                        <div class="input-group mb-2">
                            <select class="form-select border-0 shadow-none" asp-for="SelectedRating" required>
                                <option value="">Dar nota...</option>
                                <option value="5">5 - Excelente</option>
                                <option value="4">4 - Muito Boa</option>
                                <option value="3">3 - Normal</option>
                                <option value="2">2 - Pobre</option>
                                <option value="1">1 - Má</option>
                            </select>
                            <button class="btn btn-dark fw-bold" type="submit">Votar</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>