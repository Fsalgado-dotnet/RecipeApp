@page
@model RecipeApp.Web.Pages.RecipeDetailsModel
@using RecipeApp.Web.Services
@{
    ViewData["Title"] = Model.Recipe.Title;
}

<div class="row mb-4 animate__animated animate__fadeIn">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Index" class="text-success text-decoration-none">Receitas</a></li>
                <li class="breadcrumb-item active">@Model.Recipe.Title</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <h1 class="display-4 fw-bold text-dark">@Model.Recipe.Title</h1>

            @if (SessionHelper.IsLoggedIn(HttpContext))
            {
                @* Formulário de Favoritos com Handlers explícitos *@
                <form method="post" class="ms-auto">
                    @if (Model.IsFavorite)
                    {
                        <button type="submit" asp-page-handler="RemoveFavorite" asp-route-id="@Model.Recipe.RecipeId"
                                class="btn btn-danger rounded-pill px-4 shadow-sm">
                            <i class="fas fa-heart me-2"></i>Remover Favorito
                        </button>
                    }
                    else
                    {
                        <button type="submit" asp-page-handler="AddFavorite" asp-route-id="@Model.Recipe.RecipeId"
                                class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
                            <i class="far fa-heart me-2"></i>Adicionar Favorito
                        </button>
                    }
                </form>
            }
        </div>

        <div class="mt-3 d-flex gap-3 flex-wrap">
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6">
                <i class="fas fa-tag me-1"></i> @Model.Recipe.CategoryName
            </span>
            <span class="badge bg-light text-dark border rounded-pill px-3 py-2 fs-6">
                <i class="fas fa-signal text-primary me-1"></i> @Model.Recipe.DifficultyName
            </span>
            <span class="badge bg-light text-dark border rounded-pill px-3 py-2 fs-6">
                <i class="far fa-clock text-warning me-1"></i> @Model.Recipe.PreparationTime min
            </span>
        </div>
    </div>
</div>

<div class="row g-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?q=80&w=1200" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;" alt="Capa da Receita">
            <div class="card-body p-4 p-md-5">
                <h3 class="fw-bold mb-4">Modo de Preparação</h3>
                <p class="lead text-secondary" style="white-space: pre-line; line-height: 1.8;">
                    @Model.Recipe.PreparationMethod
                </p>
            </div>
        </div>

        <div class="comments-section">
            <h3 class="fw-bold mb-4"><i class="far fa-comments me-2 text-success"></i>Comentários (@(Model.Comments?.Count ?? 0))</h3>

            @if (SessionHelper.IsLoggedIn(HttpContext))
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        @* Formulário de Comentário corrigido *@
                        <form method="post" asp-page-handler="AddComment" asp-route-id="@Model.Recipe.RecipeId">
                            <div class="mb-3">
                                <textarea class="form-control border-0 bg-light" asp-for="NewComment" rows="3" placeholder="Partilhe a sua opinião sobre esta receita..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success rounded-pill px-4">Submeter Comentário</button>
                        </form>
                    </div>
                </div>
            }

            @if (Model.Comments == null || Model.Comments.Count == 0)
            {
                <div class="text-center py-4 bg-white rounded-4 shadow-sm">
                    <p class="text-muted mb-0">Ainda não há comentários. Seja o primeiro a comentar!</p>
                </div>
            }
            else
            {
                @foreach (var comment in Model.Comments)
                {
                    <div class="card border-0 shadow-sm rounded-4 mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-dark"><i class="fas fa-user-circle me-2 text-secondary"></i>@comment.UserName</span>
                                <small class="text-muted">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <p class="mb-0 text-secondary">@comment.Text</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4 sticky-top" style="top: 100px; z-index: 10;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="fw-bold mb-0">Ingredientes</h4>
                    @if (SessionHelper.IsLoggedIn(HttpContext))
                    {
                        var user = SessionHelper.GetUser(HttpContext);
                        if (SessionHelper.IsAdmin(HttpContext) || (user != null && user.UserId == Model.Recipe.CreatedByUserId))
                        {
                            <a asp-page="/EditIngredients" asp-route-recipeId="@Model.Recipe.RecipeId" class="btn btn-sm btn-outline-secondary rounded-pill">
                                <i class="fas fa-edit"></i>
                            </a>
                        }
                    }
                </div>

                @if (Model.Ingredients == null || Model.Ingredients.Count == 0)
                {
                    <p class="text-muted small">Nenhum ingrediente listado.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var ing in Model.Ingredients)
                        {
                            <li class="py-2 border-bottom d-flex justify-content-between">
                                <span class="fw-semibold text-dark">@ing.IngredientName</span>
                                <span class="text-success fw-bold">@ing.Quantity @ing.Unit</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-success text-white">
            <div class="card-body p-4 text-center">
                <h4 class="fw-bold">Avaliação</h4>
                <div class="display-4 fw-bold">@Model.AverageRating.ToString("0.0")</div>
                <div class="mb-3 text-warning">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="@(i <= Math.Round(Model.AverageRating) ? "fas" : "far") fa-star"></i>
                    }
                </div>

                @if (SessionHelper.IsLoggedIn(HttpContext))
                {
                    @* Formulário de Votação corrigido *@
                    <form method="post" asp-page-handler="Rate" asp-route-id="@Model.Recipe.RecipeId">
                        <div class="input-group mb-2">
                            <select class="form-select border-0" asp-for="SelectedRating" required>
                                <option value="">Dar nota...</option>
                                <option value="5">5 - Excelente</option>
                                <option value="4">4 - Muito Boa</option>
                                <option value="3">3 - Normal</option>
                                <option value="2">2 - Pobre</option>
                                <option value="1">1 - Má</option>
                            </select>
                            <button class="btn btn-dark" type="submit">Votar</button>
                        </div>
                    </form>
                }
                else
                {
                    <p class="small mb-0 opacity-75">Faça login para avaliar.</p>
                }
            </div>
        </div>
    </div>
</div>